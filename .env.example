# Anthropic API Key (required)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override default model
# SWARM_MODEL=claude-sonnet-4-5-20250929

# Optional: enable GPG signing for manifests
# SWARM_GPG_SIGN=false

# Optional: Postgres connection for persistent storage
# DATABASE_URL=postgresql://localhost:5432/neuron

# Vision model for image analysis (C4)
# Install: ollama pull qwen3-vl:8b
# OLLAMA_MODEL_VISION=qwen3-vl:8b
