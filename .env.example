# Anthropic API Key (required)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override default model
# SWARM_MODEL=claude-sonnet-4-5-20250929

# Optional: enable GPG signing for manifests
# SWARM_GPG_SIGN=false

# Optional: Postgres connection for persistent storage
# DATABASE_URL=postgresql://localhost:5432/neuron

# DB pool max connections
# DB_POOL_MAX=5

# Ollama URL
# OLLAMA_URL=http://localhost:11434

# Ollama embedding model
# OLLAMA_MODEL_EMBED=snowflake-arctic-embed

# Vision model for image analysis (C4)
# Install: ollama pull qwen3-vl:8b
# OLLAMA_MODEL_VISION=qwen3-vl:8b

# Ollama polish model (for transcription)
# OLLAMA_MODEL_POLISH=gemma3

# Aurora Python path
# AURORA_PYTHON_PATH=python3

# Pyannote token for speaker diarization
# PYANNOTE_TOKEN=

# Langfuse (optional telemetry)
# LANGFUSE_ENABLED=true
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=http://localhost:3000
