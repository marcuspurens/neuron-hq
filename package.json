{
  "name": "neuron-hq",
  "version": "0.1.0",
  "description": "Autonomous agent swarm control plane for developing target repos",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "neuron": "tsx src/cli.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"**/*.md\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@arizeai/openinference-instrumentation-anthropic": "^0.1.7",
    "@langfuse/otel": "^5.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/sdk-node": "^0.213.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "langfuse": "^3.38.6",
    "ora": "^8.0.1",
    "pg": "^8.19.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "keywords": [
    "agent",
    "swarm",
    "autonomous",
    "claude",
    "ai"
  ],
  "license": "MIT"
}
